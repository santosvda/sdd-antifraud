# Copie para `.env` (NUNCA commitado) e ajuste se necessário.
# Os valores abaixo já sobem o ambiente local funcional — todos fake/locais.

# --- MySQL ---
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=antifraude
# Connection string usada por api e worker (host = nome do serviço no compose).
MYSQL_CONNECTION_STRING=server=mysql;port=3306;database=antifraude;user=root;password=root

# --- SQS via LocalStack ---
# Endpoint do LocalStack (host = nome do serviço no compose). Vazio = AWS real.
SQS_SERVICE_URL=http://localstack:4566
SQS_QUEUE_NAME=sinistros
# Fila de erro técnico (não-processáveis + escalonamento). Default: <SQS_QUEUE_NAME>-erro-tecnico.
SQS_ERROR_QUEUE_NAME=sinistros-erro-tecnico
AWS_REGION=us-east-1
# Credenciais fake — LocalStack aceita qualquer valor.
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# --- Provider de score (mock) ---
# true = simular indisponibilidade do IScoreProvider (prova o fail-open / não-bloqueio).
MOCK_SCORE_PROVIDER_INDISPONIVEL=false

# --- Coleta de sinais (feature 2.2) — fontes de dados ---
# true = simular a fonte fora do ar: o sinal correspondente vira "indisponível"
# (motivo: fonte externa) e os outros 2 sinais seguem normalmente.
FONTE_IMAGENS_INDISPONIVEL=false
FONTE_APOLICES_INDISPONIVEL=false
FONTE_HISTORICO_INDISPONIVEL=false
# Resiliência por fonte: timeout da consulta e circuit breaker (N falhas consecutivas
# abrem o circuito por T segundos — chamadas seguintes falham imediato).
FONTE_TIMEOUT_SEGUNDOS=5
FONTE_BREAKER_FALHAS=3
FONTE_BREAKER_ABERTO_SEGUNDOS=30

# --- Console de Sinistros (ferramenta de operação/QA) ---
# Nome do ambiente exibido no badge do Console (fallback: ASPNETCORE_ENVIRONMENT).
CONSOLE_AMBIENTE=local
# Gate de acesso ao Console + GET /casos: local (livre) | compartilhado (Basic auth) | desabilitado.
# Cobre só o Console e a leitura de casos — NUNCA /health, POST /sinistros ou /swagger.
CONSOLE_MODO=local
# Credenciais Basic (usuario:senha) exigidas apenas quando CONSOLE_MODO=compartilhado.
CONSOLE_CREDENCIAIS=
