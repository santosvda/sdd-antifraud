# Copie para `.env` (NUNCA commitado) e ajuste se necessário.
# Os valores abaixo já sobem o ambiente local funcional — todos fake/locais.

# --- MySQL ---
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=antifraude
# Connection string usada por api e worker (host = nome do serviço no compose).
MYSQL_CONNECTION_STRING=server=mysql;port=3306;database=antifraude;user=root;password=root

# --- SQS via LocalStack ---
# Endpoint do LocalStack (host = nome do serviço no compose). Vazio = AWS real.
SQS_SERVICE_URL=http://localstack:4566
SQS_QUEUE_NAME=sinistros
AWS_REGION=us-east-1
# Credenciais fake — LocalStack aceita qualquer valor.
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# --- Provider de score (mock) ---
# true = simular indisponibilidade do IScoreProvider (prova o fail-open / não-bloqueio).
MOCK_SCORE_PROVIDER_INDISPONIVEL=false
